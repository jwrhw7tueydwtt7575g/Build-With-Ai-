# Azure Storage Configuration
# This file will be populated by Terraform outputs
# Run: terraform output > .env after applying Terraform

# Connection string for Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=

# Blob container name
AZURE_BLOB_CONTAINER_NAME=uploads

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True
